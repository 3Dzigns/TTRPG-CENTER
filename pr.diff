+/* TTRPG Center User Interface - LCARS/Star Wars Retro Terminal Design */
+
+@import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@300;400;700;900&family=Share+Tech+Mono:wght@400&display=swap');
+
+:root {
+    --lcars-orange: #ff9900;
+    --lcars-blue: #0099cc;  
+    --lcars-red: #cc6666;
+    --lcars-purple: #cc99cc;
+    --lcars-yellow: #ffff99;
+    --lcars-green: #99cc99;
+    --terminal-bg: #000;
+    --terminal-glow: #00ffff;
+    --console-text: #00ff00;
+    --warning-color: #ff6600;
+    --error-color: #ff4444;
+}
+
+body {
+    background: 
+        linear-gradient(135deg, rgba(0, 10, 20, 0.95) 0%, rgba(10, 20, 40, 0.9) 50%, rgba(20, 40, 80, 0.85) 100%),
+        url('/static/background/TTRPG_Center_BG.png') center center / cover no-repeat fixed,
+        radial-gradient(ellipse at center, rgba(0, 255, 255, 0.05) 0%, transparent 70%);
+    color: var(--terminal-glow);
+    font-family: 'Share Tech Mono', 'Orbitron', 'Courier New', monospace;
+    margin: 0;
+    padding: 0;
+    min-height: 100vh;
+    overflow-x: hidden;
+}
+
+/* LCARS Interface Layout */
+.lcars-container {
+    display: grid;
+    grid-template-columns: 200px 1fr 200px;
+    grid-template-rows: 80px 1fr 60px;
+    height: 100vh;
+    gap: 2px;
+}
+
+/* Header */
+.lcars-header {
+    grid-column: 1 / -1;
+    background: linear-gradient(90deg, var(--lcars-orange) 0%, var(--lcars-blue) 100%);
+    display: flex;
+    align-items: center;
+    padding: 0 20px;
+    position: relative;
+}
+
+.lcars-title {
+    font-family: 'Orbitron', monospace;
+    font-weight: 900;
+    font-size: 2rem;
+    color: #000;
+    text-shadow: none;
+    letter-spacing: 3px;
+}
+
+.lcars-env-badge {
+    position: absolute;
+    top: 10px;
+    right: 20px;
+    background: rgba(0, 0, 0, 0.7);
+    color: var(--lcars-yellow);
+    padding: 5px 10px;
+    border-radius: 15px;
+    font-size: 0.8rem;
+    font-weight: bold;
+}
+
+/* Left Side Panel */
+.lcars-left {
+    background: var(--lcars-purple);
+    display: flex;
+    flex-direction: column;
+    padding: 20px 10px;
+}
+
+.lcars-panel {
+    background: rgba(0, 255, 255, 0.1);
+    border: 2px solid var(--terminal-glow);
+    border-radius: 20px;
+    margin: 10px 0;
+    padding: 15px;
+    flex: 1;
+}
+
+.lcars-panel h3 {
+    color: var(--lcars-orange);
+    font-family: 'Orbitron', monospace;
+    margin: 0 0 10px 0;
+    font-size: 0.9rem;
+    text-transform: uppercase;
+}
+
+/* Right Side Panel */
+.lcars-right {
+    background: var(--lcars-red);
+    display: flex;
+    flex-direction: column;
+    padding: 20px 10px;
+}
+
+/* Main Console Area */
+.lcars-main {
+    background: var(--terminal-bg);
+    display: flex;
+    flex-direction: column;
+    padding: 20px;
+    position: relative;
+    border: 1px solid var(--terminal-glow);
+}
+
+/* Query Interface */
+.query-section {
+    background: rgba(0, 255, 255, 0.05);
+    border: 1px solid var(--terminal-glow);
+    border-radius: 8px;
+    padding: 20px;
+    margin-bottom: 20px;
+    position: relative;
+}
+
+.query-header {
+    display: flex;
+    justify-content: space-between;
+    align-items: center;
+    margin-bottom: 15px;
+}
+
+.query-title {
+    color: var(--lcars-orange);
+    font-family: 'Orbitron', monospace;
+    font-size: 1.2rem;
+    font-weight: 700;
+    margin: 0;
+}
+
+.memory-selector {
+    display: flex;
+    align-items: center;
+    gap: 10px;
+}
+
+.memory-selector label {
+    color: var(--terminal-glow);
+    font-size: 0.8rem;
+    font-weight: bold;
+}
+
+.memory-selector select {
+    background: rgba(0, 0, 0, 0.8);
+    color: var(--terminal-glow);
+    border: 1px solid var(--lcars-blue);
+    padding: 5px 10px;
+    border-radius: 4px;
+    font-family: inherit;
+}
+
+.query-input-area {
+    display: flex;
+    gap: 10px;
+    margin-bottom: 15px;
+}
+
+.query-input {
+    flex: 1;
+    background: rgba(0, 0, 0, 0.9);
+    color: var(--console-text);
+    border: 2px solid var(--terminal-glow);
+    padding: 12px 15px;
+    font-family: 'Share Tech Mono', monospace;
+    font-size: 1rem;
+    border-radius: 4px;
+    outline: none;
+    box-shadow: inset 0 0 10px rgba(0, 255, 255, 0.3);
+}
+
+.query-input:focus {
+    border-color: var(--lcars-orange);
+    box-shadow: inset 0 0 15px rgba(255, 153, 0, 0.3);
+}
+
+.query-submit {
+    background: linear-gradient(45deg, var(--lcars-orange), var(--warning-color));
+    color: #000;
+    border: none;
+    padding: 12px 25px;
+    font-family: 'Orbitron', monospace;
+    font-weight: 700;
+    border-radius: 4px;
+    cursor: pointer;
+    text-transform: uppercase;
+    letter-spacing: 1px;
+    transition: all 0.3s;
+}
+
+.query-submit:hover {
+    background: linear-gradient(45deg, var(--warning-color), var(--lcars-orange));
+    box-shadow: 0 0 15px rgba(255, 153, 0, 0.5);
+}
+
+.query-submit:disabled {
+    background: #333;
+    color: #666;
+    cursor: not-allowed;
+}
+
+/* Performance Metrics */
+.metrics-bar {
+    display: flex;
+    justify-content: space-between;
+    align-items: center;
+    font-size: 0.8rem;
+    color: var(--terminal-glow);
+    border-top: 1px solid rgba(0, 255, 255, 0.3);
+    padding-top: 10px;
+}
+
+.metric-item {
+    display: flex;
+    align-items: center;
+    gap: 5px;
+}
+
+.metric-value {
+    color: var(--lcars-yellow);
+    font-weight: bold;
+}
+
+.timer {
+    color: var(--lcars-green);
+    font-family: 'Share Tech Mono', monospace;
+}
+
+/* Response Area */
+.response-section {
+    flex: 1;
+    background: rgba(0, 255, 255, 0.02);
+    border: 1px solid var(--terminal-glow);
+    border-radius: 8px;
+    padding: 20px;
+    position: relative;
+    min-height: 300px;
+}
+
+.response-header {
+    color: var(--lcars-orange);
+    font-family: 'Orbitron', monospace;
+    font-size: 1.2rem;
+    font-weight: 700;
+    margin: 0 0 15px 0;
+    border-bottom: 1px solid rgba(0, 255, 255, 0.3);
+    padding-bottom: 10px;
+}
+
+.response-content {
+    color: var(--terminal-glow);
+    font-family: 'Share Tech Mono', monospace;
+    line-height: 1.6;
+    max-height: 400px;
+    overflow-y: auto;
+    padding-right: 10px;
+}
+
+.response-loading {
+    display: flex;
+    align-items: center;
+    justify-content: center;
+    height: 200px;
+    color: var(--lcars-yellow);
+    font-size: 1.1rem;
+}
+
+.loading-spinner {
+    display: inline-block;
+    width: 20px;
+    height: 20px;
+    border: 3px solid rgba(0, 255, 255, 0.3);
+    border-radius: 50%;
+    border-top: 3px solid var(--lcars-yellow);
+    animation: spin 1s linear infinite;
+    margin-right: 10px;
+}
+
+@keyframes spin {
+    0% { transform: rotate(0deg); }
+    100% { transform: rotate(360deg); }
+}
+
+.source-toggle {
+    position: absolute;
+    top: 15px;
+    right: 15px;
+    background: rgba(0, 0, 0, 0.7);
+    color: var(--terminal-glow);
+    border: 1px solid var(--lcars-blue);
+    padding: 5px 10px;
+    border-radius: 4px;
+    font-size: 0.8rem;
+    cursor: pointer;
+}
+
+.source-toggle:hover {
+    background: rgba(0, 153, 204, 0.2);
+}
+
+/* Status Indicators */
+.status-indicator {
+    width: 12px;
+    height: 12px;
+    border-radius: 50%;
+    display: inline-block;
+    margin-right: 8px;
+}
+
+.status-ok {
+    background: var(--lcars-green);
+    box-shadow: 0 0 8px var(--lcars-green);
+}
+
+.status-warning {
+    background: var(--lcars-yellow);
+    box-shadow: 0 0 8px var(--lcars-yellow);
+}
+
+.status-error {
+    background: var(--error-color);
+    box-shadow: 0 0 8px var(--error-color);
+}
+
+/* Footer */
+.lcars-footer {
+    grid-column: 1 / -1;
+    background: linear-gradient(90deg, var(--lcars-blue) 0%, var(--lcars-purple) 100%);
+    display: flex;
+    align-items: center;
+    justify-content: space-between;
+    padding: 0 20px;
+    color: #000;
+    font-weight: bold;
+}
+
+.admin-link {
+    color: #000;
+    text-decoration: none;
+    background: rgba(255, 255, 255, 0.2);
+    padding: 5px 10px;
+    border-radius: 15px;
+    transition: all 0.3s;
+}
+
+.admin-link:hover {
+    background: rgba(255, 255, 255, 0.4);
+}
+
+/* Scrollbar Styling */
+.response-content::-webkit-scrollbar {
+    width: 8px;
+}
+
+.response-content::-webkit-scrollbar-track {
+    background: rgba(0, 0, 0, 0.5);
+    border-radius: 4px;
+}
+
+.response-content::-webkit-scrollbar-thumb {
+    background: var(--terminal-glow);
+    border-radius: 4px;
+}
+
+.response-content::-webkit-scrollbar-thumb:hover {
+    background: var(--lcars-orange);
+}
+
+/* Mobile Responsiveness */
+@media (max-width: 768px) {
+    .lcars-container {
+        grid-template-columns: 1fr;
+        grid-template-rows: 60px 1fr 50px;
+    }
+    
+    .lcars-left, .lcars-right {
+        display: none;
+    }
+    
+    .lcars-title {
+        font-size: 1.5rem;
+    }
+    
+    .query-input-area {
+        flex-direction: column;
+    }
+}
