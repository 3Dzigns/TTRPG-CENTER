+                except Exception as e:
+                    if ingestion_id in ingestion_status:
+                        ingestion_status[ingestion_id].update({
+                            "status": "error",
+                            "phase": "error",
+                            "current_step": f"Error in file {i+1}: {str(e)}",
+                            "end_time": time.time()
