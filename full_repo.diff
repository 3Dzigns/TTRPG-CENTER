+            )
+            
+            # Format response
+            response = {
+                "query_id": query_id,
+                "query": query,
+                "response": result.get("response", "No response generated"),
+                "query_type": query_type.value,
+                "routing_confidence": routing_result.get("confidence", 0.0),
