+                    return
+                
+                success = bug_tracker.admin_close_bug(bug_id, reason)
+                if success:
+                    self._send(200, {"success": True, "message": f"Bug {bug_id} closed by admin"})
+                else:
+                    self._send(400, {"success": False, "error": "Failed to close bug - check admin permissions"})
