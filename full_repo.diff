+                        
+                        let historyHtml = '';
+                        if (data.ingestions.length > 0) {{
+                            data.ingestions.forEach(ing => {{
+                                const statusColor = ing.status === 'completed' ? '#00ff00' : 
+                                                  ing.status === 'error' ? '#ff4444' : '#ffaa00';
