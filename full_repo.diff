+                    const result = data.cleanup_result;
+                    let html = '<div class="cleanup-result">';
+                    html += '<strong>Cleanup Complete:</strong><br>';
+                    html += 'Environment: <span style="color: #ff6600;">' + data.environment.toUpperCase() + '</span><br>';
