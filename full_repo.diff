+                fp=self.rfile,
+                headers=self.headers,
+                environ={
+                    'REQUEST_METHOD': 'POST',
+                    'CONTENT_TYPE': content_type,
+                }
+            )
+            
+            if 'file' not in form:
+                self._send(400, {"error": "no files uploaded"})
+                return
+            
+            # Handle both single and multiple files
+            files = form['file'] if isinstance(form['file'], list) else [form['file']]
